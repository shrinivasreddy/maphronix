# Copy this file to .env and fill in real values.
# Never commit the real .env file to git or share it publicly.

# ── exiftool ────────────────────────────────────────────────────────────
# Path to exiftool.exe (Windows) or exiftool (Mac/Linux).
# If exiftool is on your system PATH, "exiftool" is enough.
EXIFTOOL_PATH=exiftool

# Runtime
APP_TIMEZONE=Asia/Kolkata
APP_HOST=127.0.0.1
APP_PORT=5000
APP_DEBUG=false
UPLOAD_FOLDER=uploads
LOG_FILE_PATH=maphronix_activity_log.txt
ALLOWED_EXTENSIONS=.mp4,.mov

# Maximum total upload request size. Use values like 20GB, 512MB, or bytes.
# Set this above your largest expected video or batch of videos.
MAX_UPLOAD_SIZE=20GB

# Large videos can take a while for exiftool to scan for embedded GPS.
EXIFTOOL_TIMEOUT_SECONDS=1800
CHUNK_SIZE_BYTES=8388608

# ── Flask session security ─────────────────────────────────────────────
# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ── App login ───────────────────────────────────────────────────────────
# The shared password required to log into the app.
# IMPORTANT: change this from whatever was hardcoded in the original .exe --
# that value should be considered compromised.
APP_LOGIN_PASSWORD=

# Map/frontend settings
LEAFLET_CSS_URL=https://unpkg.com/leaflet/dist/leaflet.css
LEAFLET_JS_URL=https://unpkg.com/leaflet/dist/leaflet.js
MAP_TILE_URL=https://mt{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}
MAP_TILE_SUBDOMAINS=0,1,2,3
MAP_TILE_MAX_ZOOM=21
SCREENSHOT_WIDTH=5312
SCREENSHOT_HEIGHT=2988

# ── Email notifications (optional) ─────────────────────────────────────
# If you leave these blank, the app runs fine -- it just skips sending
# login-alert / activity-log emails.
# For Gmail, EMAIL_PASSWORD must be a 16-character App Password, not your
# normal account password: https://myaccount.google.com/apppasswords
# IMPORTANT: generate a NEW app password -- do not reuse the one from the
# original .exe, since that one should be considered compromised.
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
IP_LOOKUP_URL=http://ip-api.com/json
IP_LOOKUP_TIMEOUT_SECONDS=5
